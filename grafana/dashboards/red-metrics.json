{
  "title": "FruitStore observability",
  "uid": "fruit-app-red-complete",
  "tags": ["application"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 38,
  "panels": [

    {
      "id": 100,
      "type": "row",
      "title": "KPIs Principais (RED)",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 1,
      "type": "stat",
      "title": "Rate (Req/sec)",
      "gridPos": { "x": 0, "y": 1, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":20}] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_requests_total[1m]))" }]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": { "x": 5, "y": 1, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":10}] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "(sum(rate(fruit_app_errors_total[1m])) / sum(rate(fruit_app_requests_total[1m]))) * 100" }]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": { "x": 10, "y": 1, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(fruit_app_requests_total)" }]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Total Errors",
      "gridPos": { "x": 15, "y": 1, "w": 5, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(fruit_app_errors_total)" }]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Avg Latency (ms)",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 0 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_request_duration_seconds_sum[5m])) / sum(rate(fruit_app_request_duration_seconds_count[5m])) * 1000" }]
    },

    {
      "id": 101,
      "type": "row",
      "title": "RATE: Request Volume & Trends",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Rate Over Time",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_requests_total[30s]))", "legendFormat": "Total" },
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_requests_total{method=\"GET\"}[30s]))", "legendFormat": "GET" },
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_requests_total{method=\"POST\"}[30s]))", "legendFormat": "POST" }
      ]
    },

    {
      "id": 11,
      "type": "piechart",
      "title": "Request Distribution by Endpoint",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "pieType": "pie", "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum by (endpoint) (fruit_app_requests_total)", "legendFormat": "{{endpoint}}" }]
    },

    {
      "id": 102,
      "type": "row",
      "title": "ERRORS: Error Tracking & Analysis",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "Error Rate Over Time (per minute)",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity" },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_errors_total{status=\"404\"}[1m]))", "legendFormat": "404 Not Found" },
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_errors_total{status=\"500\"}[1m]))", "legendFormat": "500 Server Error" },
        { "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_errors_total{status=\"400\"}[1m]))", "legendFormat": "400 Bad Request" }
      ]
    },

    {
      "id": 21,
      "type": "barchart",
      "title": "Error Count by Status Code",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum by (status) (fruit_app_errors_total)", "legendFormat": "{{status}}" }]
    },

    {
      "id": 103,
      "type": "row",
      "title": "DURATION: Latency Analysis & Percentiles",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 30,
      "type": "timeseries",
      "title": "Latency Percentiles: p50 / p95 / p99 / p99.9",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 0, "gradientMode": "none", "showPoints": "never" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(fruit_app_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p50" },
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(fruit_app_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95" },
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(fruit_app_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p99" },
        { "datasource": { "uid": "prometheus" }, "expr": "histogram_quantile(0.999, sum(rate(fruit_app_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p99.9" }
      ]
    },

    {
      "id": 31,
      "type": "heatmap",
      "title": "Latency Distribution Heatmap",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "options": { "legend": { "show": true }, "color": { "scheme": "Viridis" }, "tooltip": { "show": true } },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum(rate(fruit_app_request_duration_seconds_bucket[5m])) by (le)" }]
    },

    {
      "id": 104,
      "type": "row",
      "title": "ENDPOINT ANALYSIS: Performance by Route",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 40,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "sum by (endpoint) (rate(fruit_app_requests_total[1m]))", "legendFormat": "{{endpoint}}" }]
    },

    {
      "id": 105,
      "type": "row",
      "title": "SUMMARY: All Endpoints Performance",
      "gridPos": { "x": 0, "y": 33, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 50,
      "type": "table",
      "title": "Endpoint Performance Summary",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Rate", "desc": true }] },
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (endpoint) (rate(fruit_app_requests_total[5m]))", "format": "table", "instant": true, "refId": "A" }
      ]
    }

  ]
}